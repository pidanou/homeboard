# PostgreSQL
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://familyboard:${POSTGRES_PASSWORD}@localhost:5432/familyboard?sslmode=disable

# Backend
JWT_SECRET=change-me-to-a-long-random-secret
PORT=8080
# Public URL of the backend API — used to build avatar URLs stored in the database
API_BASE_URL=http://localhost:8080
# Comma-separated extra CORS origins, or * to allow all (e.g. for Capacitor apps)
CORS_ALLOWED_ORIGINS=
# Frontend URL added to CORS allowed origins
APP_BASE_URL=

# Web
PUBLIC_API_URL=http://localhost:8080

UPLOAD_DIR=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
